# ── Database (Neon) ───────────────────────────────────────────────────────────
# Copy the connection string from your Neon project dashboard.
# The string already contains the host, user, password, and database name.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Required for Neon (and any hosted Postgres that enforces SSL).
DATABASE_SSL=true

# ── External API keys ─────────────────────────────────────────────────────────
TWELVE_DATA_API_KEY=your_twelve_data_key
NEWS_API_KEY=your_marketaux_key
FINNHUB_API_KEY=your_finnhub_key
OPENAI_API_KEY=your_openai_key   # optional — AI sentiment and chat are disabled if absent

# ── Python indicators service ─────────────────────────────────────────────────
# On Render: set this to the public URL of your deployed indicators service.
# On Docker: set this to http://indicators:8000
PYTHON_SERVICE_URL=https://your-indicators-service.onrender.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# On Render: set this to your Netlify frontend URL (no trailing slash).
# On Docker / local: http://localhost:3000
CORS_ORIGIN=https://your-app.netlify.app

# ── Server ────────────────────────────────────────────────────────────────────
# Render sets PORT automatically — do not override it on Render.
# HOST must be 0.0.0.0 so the container/VM accepts external connections.
HOST=0.0.0.0
# PORT=3001  # only needed locally or in Docker
