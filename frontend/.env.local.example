# ── API URL ───────────────────────────────────────────────────────────────────
# This value is baked into the client-side bundle at BUILD time (not runtime).
#
# On Netlify: set this as a build environment variable in the Netlify dashboard
#   Site → Site configuration → Environment variables
#   Value: the public URL of your Render API service (no trailing slash)
#
# Locally: defaults to http://localhost:3001 if this file is absent.
NEXT_PUBLIC_API_URL=https://your-api-service.onrender.com
